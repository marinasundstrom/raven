{
  "name": "raven-vscode",
  "displayName": "Raven",
  "description": "VS Code extension for the Raven language server.",
  "version": "0.1.0",
  "publisher": "raven",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:raven",
    "onDebug:raven",
    "onCommand:raven.run.compileAndRun",
    "onCommand:raven.debug.compileAndDebug",
    "onCommand:raven.build.activeTarget",
    "onCommand:raven.build.clean",
    "onCommand:raven.showMacroExpansion",
    "onCommand:raven.showCodeActionPreview",
    "onCommand:raven.openDocumentation"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "raven",
        "aliases": [
          "Raven",
          "raven"
        ],
        "extensions": [
          ".rvn",
          ".rav"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "commands": [
      {
        "command": "raven.run.compileAndRun",
        "title": "Raven: Compile and Run"
      },
      {
        "command": "raven.debug.compileAndDebug",
        "title": "Raven: Compile and Debug"
      },
      {
        "command": "raven.build.activeTarget",
        "title": "Raven: Build Active File/Project"
      },
      {
        "command": "raven.build.clean",
        "title": "Raven: Clean Build Artifacts"
      },
      {
        "command": "raven.showMacroExpansion",
        "title": "Raven: Show Macro Expansion"
      },
      {
        "command": "raven.showCodeActionPreview",
        "title": "Raven: Show Code Action Preview"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "raven.run.compileAndRun",
          "when": "resourceExtname == .rvn || resourceExtname == .rav || resourceExtname == .ravenproj || resourceExtname == .rvnproj",
          "group": "navigation"
        },
        {
          "command": "raven.debug.compileAndDebug",
          "when": "resourceExtname == .rvn || resourceExtname == .rav || resourceExtname == .ravenproj || resourceExtname == .rvnproj",
          "group": "navigation"
        },
        {
          "command": "raven.build.activeTarget",
          "when": "resourceExtname == .rvn || resourceExtname == .rav || resourceExtname == .ravenproj || resourceExtname == .rvnproj",
          "group": "navigation@1"
        },
        {
          "command": "raven.build.clean",
          "when": "resourceExtname == .rvn || resourceExtname == .rav || resourceExtname == .ravenproj || resourceExtname == .rvnproj",
          "group": "navigation@2"
        }
      ]
    },
    "debuggers": [
      {
        "type": "raven",
        "label": "Raven",
        "languages": [
          "raven"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [],
            "properties": {
              "target": {
                "type": "string",
                "description": "Path to a .rvn, .rvnproj, .rav, or .ravenproj file. Defaults to the active editor file."
              },
              "project": {
                "type": "string",
                "description": "Alias for target when launching a Raven project file."
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "raven",
            "request": "launch",
            "name": "Raven: Compile and Debug",
            "target": "${file}"
          }
        ]
      }
    ],
    "breakpoints": [
      {
        "language": "raven"
      }
    ],
    "grammars": [
      {
        "language": "raven",
        "scopeName": "source.raven",
        "path": "./syntaxes/raven.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Raven",
      "properties": {
        "raven.languageServerPath": {
          "type": "string",
          "default": "",
          "description": "Full path to Raven.LanguageServer.dll. Leave empty to auto-discover a sibling 'server/Raven.LanguageServer.dll' next to the extension or a workspace copy under src/Raven.LanguageServer/bin/Debug/net10.0."
        },
        "raven.compilerProjectPath": {
          "type": "string",
          "default": "",
          "description": "Full path to Raven.Compiler.csproj used by Raven debug launch. Leave empty to auto-discover '<workspace>/src/Raven.Compiler/Raven.Compiler.csproj'."
        },
        "raven.targetFramework": {
          "type": "string",
          "default": "",
          "description": "Target framework to pass to Raven debug compile (for both dotnet run and Raven.Compiler --framework), for example 'net10.0'. Leave empty to use defaults."
        },
        "raven.debugStopAtEntry": {
          "type": "boolean",
          "default": false,
          "description": "Pause at program entry before user code runs when launching Raven debug sessions."
        },
        "raven.debugJustMyCode": {
          "type": "boolean",
          "default": false,
          "description": "Use Just My Code when launching Raven debug sessions. Some Raven builds may be classified as non-user code by vsdbg when this is enabled."
        },
        "raven.debugModuleLoadMessages": {
          "type": "boolean",
          "default": false,
          "description": "Show module-load messages in the Debug Console for Raven debug sessions."
        },
        "raven.debugEngineLogging": {
          "type": "boolean",
          "default": false,
          "description": "Enable verbose debugger engine logging for Raven debug sessions."
        },
        "raven.debugExcludeFrameworkModules": {
          "type": "boolean",
          "default": true,
          "description": "Exclude System.* and Microsoft.* modules from symbol loading to reduce framework symbol noise in Raven debug sessions."
        }
      }
    },
    "configurationDefaults": {
      "[raven]": {
        "editor.colorDecorators": false
      },
      "files.associations": {
        "*.rvnproj": "xml",
        "*.ravenproj": "xml"
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./tsconfig.json",
    "watch": "tsc -watch -p ./tsconfig.json",
    "lint": "echo 'No lint configuration'",
    "prepare": "npm run compile",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "1.80.0",
    "typescript": "^5.4.5",
    "@vscode/vsce": "^3.7.1"
  }
}
