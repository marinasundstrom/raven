{
  "name": "raven-vscode",
  "displayName": "Raven",
  "description": "VS Code extension for the Raven language server.",
  "version": "0.1.0",
  "publisher": "raven",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:raven",
    "onDebug:raven",
    "onCommand:raven.run.compileAndRun",
    "onCommand:raven.debug.compileAndDebug",
    "onCommand:raven.build.activeTarget",
    "onCommand:raven.build.clean",
    "onCommand:raven.showMacroExpansion",
    "onCommand:raven.showCodeActionPreview",
    "onCommand:raven.openDocumentation"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "raven",
        "aliases": [
          "Raven",
          "raven"
        ],
        "extensions": [
          ".rvn",
          ".rav"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "commands": [
      {
        "command": "raven.run.compileAndRun",
        "title": "Raven: Compile and Run"
      },
      {
        "command": "raven.debug.compileAndDebug",
        "title": "Raven: Compile and Debug"
      },
      {
        "command": "raven.build.activeTarget",
        "title": "Raven: Build Active File/Project"
      },
      {
        "command": "raven.build.clean",
        "title": "Raven: Clean Build Artifacts"
      },
      {
        "command": "raven.showMacroExpansion",
        "title": "Raven: Show Macro Expansion"
      },
      {
        "command": "raven.showCodeActionPreview",
        "title": "Raven: Show Code Action Preview"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "raven.run.compileAndRun",
          "when": "resourceExtname == .rvn || resourceExtname == .rav || resourceExtname == .ravenproj || resourceExtname == .rvnproj",
          "group": "navigation"
        },
        {
          "command": "raven.debug.compileAndDebug",
          "when": "resourceExtname == .rvn || resourceExtname == .rav || resourceExtname == .ravenproj || resourceExtname == .rvnproj",
          "group": "navigation"
        },
        {
          "command": "raven.build.activeTarget",
          "when": "resourceExtname == .rvn || resourceExtname == .rav || resourceExtname == .ravenproj || resourceExtname == .rvnproj",
          "group": "navigation@1"
        },
        {
          "command": "raven.build.clean",
          "when": "resourceExtname == .rvn || resourceExtname == .rav || resourceExtname == .ravenproj || resourceExtname == .rvnproj",
          "group": "navigation@2"
        }
      ]
    },
    "debuggers": [
      {
        "type": "raven",
        "label": "Raven",
        "languages": [
          "raven"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [],
            "properties": {
              "target": {
                "type": "string",
                "description": "Path to a .rvn, .rvnproj, .rav, or .ravenproj file. Defaults to the active editor file."
              },
              "project": {
                "type": "string",
                "description": "Alias for target when launching a Raven project file."
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "raven",
            "request": "launch",
            "name": "Raven: Compile and Debug",
            "target": "${file}"
          }
        ]
      }
    ],
    "breakpoints": [
      {
        "language": "raven"
      }
    ],
    "grammars": [
      {
        "language": "raven",
        "scopeName": "source.raven",
        "path": "./syntaxes/raven.tmLanguage.json"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "raven",
        "scopes": {
          "keyword": [
            "keyword.other.using.raven",
            "keyword.other.alias.raven",
            "keyword.control.conditional.raven",
            "keyword.control.loop.raven",
            "keyword.control.exception.raven",
            "keyword.control.flow.raven",
            "keyword.control.async.raven",
            "keyword.declaration.constraint.raven",
            "keyword.other.expression.raven",
            "keyword.control.raven",
            "keyword.other.conversion.raven",
            "keyword.other.raven",
            "keyword"
          ],
          "string": [
            "string.quoted.double.raven"
          ],
          "number": [
            "constant.numeric.raven"
          ],
          "comment": [
            "comment.raven"
          ],
          "operator": [
            "keyword.operator.word.raven",
            "keyword.operator.raven"
          ],
          "namespace": [
            "entity.name.namespace.raven",
            "entity.name.namespace"
          ],
          "type": [
            "entity.name.type.raven",
            "entity.name.type"
          ],
          "class": [
            "entity.name.type.raven",
            "entity.name.type"
          ],
          "struct": [
            "entity.name.type.raven",
            "entity.name.type"
          ],
          "interface": [
            "entity.name.type.raven",
            "entity.name.type"
          ],
          "enum": [
            "entity.name.type.raven",
            "entity.name.type"
          ],
          "method": [
            "entity.name.function.raven",
            "entity.name.function"
          ],
          "property": [
            "variable.other.property.raven",
            "variable.other.property",
            "variable.other"
          ],
          "variable": [
            "variable.other.raven",
            "variable.other"
          ],
          "parameter": [
            "variable.parameter.raven",
            "variable.parameter"
          ],
          "label": [
            "entity.name.label.raven",
            "entity.name.label"
          ],
          "event": [
            "entity.name.event.raven",
            "entity.name.event",
            "variable.other.property"
          ],
          "type.defaultLibrary": [
            "support.type.builtin.raven",
            "support.type"
          ],
          "class.defaultLibrary": [
            "support.type.builtin.raven",
            "support.type"
          ],
          "struct.defaultLibrary": [
            "support.type.builtin.raven",
            "support.type"
          ],
          "method.defaultLibrary": [
            "support.function.raven",
            "support.function"
          ],
          "property.readonly": [
            "variable.other.constant.property.raven",
            "variable.other.property.raven",
            "variable.other.property"
          ],
          "variable.readonly": [
            "variable.other.constant.raven",
            "variable.other.raven",
            "variable.other"
          ],
          "parameter.readonly": [
            "variable.parameter.raven",
            "variable.parameter"
          ]
        }
      }
    ],
    "configuration": {
      "title": "Raven",
      "properties": {
        "raven.languageServerPath": {
          "type": "string",
          "default": "",
          "description": "Full path to Raven.LanguageServer.dll. Leave empty to auto-discover a sibling 'server/Raven.LanguageServer.dll' next to the extension or a workspace copy under src/Raven.LanguageServer/bin/Debug/net10.0."
        },
        "raven.autoBuildLanguageServerOnActivate": {
          "type": "boolean",
          "default": true,
          "description": "When the extension can find src/Raven.LanguageServer/Raven.LanguageServer.csproj in the current workspace or extension ancestors, build it on activation before launching the language server. Ignored when raven.languageServerPath is set."
        },
        "raven.sdkPath": {
          "type": "string",
          "default": "",
          "description": "Optional path to a Raven SDK directory containing bundled tools and assemblies such as Raven.LanguageServer.dll, rvn.dll, and Raven.Core.dll. When set, the extension prefers this SDK for language-server and compiler resolution."
        },
        "raven.compilerProjectPath": {
          "type": "string",
          "default": "",
          "description": "Optional path used to locate a built Raven compiler host (rvn.dll) under src/Raven.Compiler/bin/Debug/<tfm>. The extension does not launch Raven.Compiler.csproj via dotnet run."
        },
        "raven.targetFramework": {
          "type": "string",
          "default": "",
          "description": "Target framework to pass to Raven debug compile through the built Raven compiler host, for example 'net10.0'. Leave empty to use defaults."
        },
        "raven.debugStopAtEntry": {
          "type": "boolean",
          "default": false,
          "description": "Pause at program entry before user code runs when launching Raven debug sessions."
        },
        "raven.debugJustMyCode": {
          "type": "boolean",
          "default": false,
          "description": "Use Just My Code when launching Raven debug sessions. Some Raven builds may be classified as non-user code by vsdbg when this is enabled."
        },
        "raven.debugModuleLoadMessages": {
          "type": "boolean",
          "default": false,
          "description": "Show module-load messages in the Debug Console for Raven debug sessions."
        },
        "raven.debugEngineLogging": {
          "type": "boolean",
          "default": false,
          "description": "Enable verbose debugger engine logging for Raven debug sessions."
        },
        "raven.debugExcludeFrameworkModules": {
          "type": "boolean",
          "default": true,
          "description": "Exclude System.* and Microsoft.* modules from symbol loading to reduce framework symbol noise in Raven debug sessions."
        }
      }
    },
    "configurationDefaults": {
      "[raven]": {
        "editor.colorDecorators": false
      },
      "files.associations": {
        "*.rvnproj": "xml",
        "*.ravenproj": "xml"
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./tsconfig.json",
    "watch": "tsc -watch -p ./tsconfig.json",
    "lint": "echo 'No lint configuration'",
    "prepare": "npm run compile",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "1.80.0",
    "typescript": "^5.4.5",
    "@vscode/vsce": "^3.7.1"
  }
}
