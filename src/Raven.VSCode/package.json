{
  "name": "raven-vscode",
  "displayName": "Raven",
  "description": "VS Code extension for the Raven language server.",
  "version": "0.1.0",
  "publisher": "raven",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:raven",
    "onDebug:raven",
    "onCommand:raven.debug.compileAndDebug"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "raven",
        "aliases": [
          "Raven",
          "raven"
        ],
        "extensions": [
          ".rav"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "commands": [
      {
        "command": "raven.debug.compileAndDebug",
        "title": "Raven: Compile and Debug Active File"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "raven.debug.compileAndDebug",
          "when": "resourceExtname == .rav || resourceExtname == .ravenproj",
          "group": "navigation"
        }
      ]
    },
    "debuggers": [
      {
        "type": "raven",
        "label": "Raven",
        "languages": [
          "raven"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [],
            "properties": {
              "target": {
                "type": "string",
                "description": "Path to a .rav or .ravenproj file. Defaults to the active editor file."
              },
              "project": {
                "type": "string",
                "description": "Alias for target when launching a .ravenproj file."
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "raven",
            "request": "launch",
            "name": "Raven: Compile and Debug",
            "target": "${file}"
          }
        ]
      }
    ],
    "breakpoints": [
      {
        "language": "raven"
      }
    ],
    "grammars": [
      {
        "language": "raven",
        "scopeName": "source.raven",
        "path": "./syntaxes/raven.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Raven",
      "properties": {
        "raven.languageServerPath": {
          "type": "string",
          "default": "",
          "description": "Full path to Raven.LanguageServer.dll. Leave empty to auto-discover a sibling 'server/Raven.LanguageServer.dll' next to the extension or a workspace copy under src/Raven.LanguageServer/bin/Debug/net9.0."
        },
        "raven.compilerProjectPath": {
          "type": "string",
          "default": "",
          "description": "Full path to Raven.Compiler.csproj used by Raven debug launch. Leave empty to auto-discover '<workspace>/src/Raven.Compiler/Raven.Compiler.csproj'."
        },
        "raven.targetFramework": {
          "type": "string",
          "default": "",
          "description": "Target framework to pass to Raven debug compile (for both dotnet run and Raven.Compiler --framework), for example 'net9.0'. Leave empty to use defaults."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./tsconfig.json",
    "watch": "tsc -watch -p ./tsconfig.json",
    "lint": "echo 'No lint configuration'",
    "prepare": "npm run compile",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "1.80.0",
    "typescript": "^5.4.5",
    "@vscode/vsce": "^3.7.1"
  }
}
