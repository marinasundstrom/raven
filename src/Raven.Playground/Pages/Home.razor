@page "/"
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject HttpClient Http
@inject NavigationManager Navigation
@inject PlaygroundLanguageService LanguageService
@inject PlaygroundProgramRunner Runner

<PageTitle>Raven Playground</PageTitle>

<section class="playground-shell">
    <header class="hero">
        <div>
            <p class="eyebrow">Raven · browser WebAssembly</p>
            <h1>Write Raven. Run it here.</h1>
            <p class="lede">The compiler and program execute locally. Your source stays in this browser.</p>
        </div>
        <div class="runtime-badge"><span class="status-dot"></span>.NET WebAssembly</div>
    </header>

    <div class="workspace">
        <section class="panel editor-panel" aria-labelledby="editor-heading">
            <div class="panel-header">
                <div>
                    <span class="panel-kicker">Source</span>
                    <h2 id="editor-heading">main.rav</h2>
                </div>
                <label class="example-picker">
                    <span>Example</span>
                    <select value="@_selectedExampleId" disabled="@_isBusy" @onchange="SelectExampleAsync">
                        @if (string.IsNullOrEmpty(_selectedExampleId))
                        {
                            <option value="">Shared program</option>
                        }
                        @foreach (var example in _examples)
                        {
                            <option value="@example.Id">@example.Title</option>
                        }
                    </select>
                </label>
                <div class="actions">
                    <button class="compile-button" type="button" disabled="@_isBusy" @onclick="CompileAsync">
                        Compile <kbd>F6</kbd>
                    </button>
                    <button class="run-button" type="button" disabled="@_isBusy" @onclick="CompileAndRunAsync">
                        @(_isBusy ? "Working…" : "Run") <span aria-hidden="true">▶</span>
                    </button>
                    <button class="share-button" type="button" disabled="@_isBusy" @onclick="ShareAsync">
                        Share
                    </button>
                    <span class="share-status" aria-live="polite">@_shareStatus</span>
                </div>
            </div>
            <div class="source-editor" @ref="_editorElement" aria-label="Raven source editor"></div>
        </section>

        <section class="panel output-panel" aria-labelledby="output-heading">
            <div class="panel-header">
                <div>
                    <span class="panel-kicker">Result</span>
                    <h2 id="output-heading">Output</h2>
                </div>
                <span class="status-pill @StatusClass">@_status</span>
            </div>
            <pre class="program-output">@_output</pre>
            @if (_diagnostics.Count > 0)
            {
                <div class="diagnostics" aria-live="polite">
                    <h3>Diagnostics</h3>
                    <ul>
                        @foreach (var diagnostic in _diagnostics)
                        {
                            <li>@diagnostic</li>
                        }
                    </ul>
                </div>
            }
        </section>
    </div>

    <footer class="playground-footer">
        <span>TextMate syntax highlighting</span>
        <span>•</span>
        <span>Compiler-backed completion</span>
        <span>•</span>
        <span>Runs entirely on your device</span>
    </footer>
</section>

@code {
    private ElementReference _editorElement;
    private IJSObjectReference? _module;
    private IJSObjectReference? _editor;
    private DotNetObjectReference<Home>? _commandTarget;
    private string _output = "Press Compile to check the program, or Run to execute it.";
    private string _status = "Loading editor";
    private string _selectedExampleId = string.Empty;
    private string _initialSource = string.Empty;
    private string _shareStatus = string.Empty;
    private bool _initialSourceLoaded;
    private bool _isBusy;
    private IReadOnlyList<string> _diagnostics = [];
    private IReadOnlyList<PlaygroundExampleEntry> _examples = [];

    private string StatusClass => _status switch
    {
        "Complete" or "Compiled" => "status-success",
        "Compile error" or "Runtime error" => "status-error",
        "Compiling" or "Running" => "status-active",
        _ => string.Empty,
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadInitialSourceAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await LoadInitialSourceAsync();
        _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/editor.js");
        _commandTarget = DotNetObjectReference.Create(this);
        _editor = await _module.InvokeAsync<IJSObjectReference>(
            "createEditor",
            _editorElement,
            string.Empty,
            _commandTarget);
        await _editor.InvokeVoidAsync("setValue", _initialSource);
        _status = "Ready";
        StateHasChanged();
    }

    [JSInvokable]
    public Task InvokeEditorCommand(string command) =>
        command == "run" ? CompileAndRunAsync() : CompileAsync();

    [JSInvokable]
    public async Task<IReadOnlyList<PlaygroundCompletionItem>> GetCompletions(string source, int position)
    {
        await Task.Yield();
        return LanguageService.GetCompletions(source, position);
    }

    private Task CompileAsync() => CompileCoreAsync(run: false);

    private Task CompileAndRunAsync() => CompileCoreAsync(run: true);

    private async Task SelectExampleAsync(ChangeEventArgs args)
    {
        var id = args.Value?.ToString();
        var example = _examples.FirstOrDefault(example =>
            string.Equals(example.Id, id, StringComparison.Ordinal));
        if (example is null || _editor is null)
            return;

        _selectedExampleId = example.Id;
        var source = await Http.GetStringAsync($"examples/{example.File}");
        await _editor.InvokeVoidAsync("setValue", source);
        if (_module is not null)
            await _module.InvokeVoidAsync("clearSharedSource");
        _status = "Ready";
        _output = $"Loaded “{example.Title}”. Press Run to execute it.";
        _shareStatus = string.Empty;
        _diagnostics = [];
    }

    private async Task ShareAsync()
    {
        if (_editor is null || _module is null)
            return;

        var source = await _editor.InvokeAsync<string>("getValue");
        var encodedSource = EncodeSource(source);
        var copied = await _module.InvokeAsync<bool>("setSharedSource", encodedSource);
        _selectedExampleId = string.Empty;
        _shareStatus = copied ? "Link copied" : "Link ready";
    }

    private async Task LoadInitialSourceAsync()
    {
        if (_initialSourceLoaded)
            return;

        _examples = await Http.GetFromJsonAsync<PlaygroundExampleEntry[]>("examples/index.json") ?? [];
        if (TryGetQueryParameter(new Uri(Navigation.Uri), "source", out var encodedSource) &&
            TryDecodeSource(encodedSource, out var sharedSource))
        {
            _initialSource = sharedSource;
            _selectedExampleId = string.Empty;
            _initialSourceLoaded = true;
            return;
        }

        var initialExample = _examples.FirstOrDefault(static example => example.Id == "hello")
            ?? _examples.FirstOrDefault();
        if (initialExample is null)
            return;

        _selectedExampleId = initialExample.Id;
        _initialSource = await Http.GetStringAsync($"examples/{initialExample.File}");
        _initialSourceLoaded = true;
    }

    private static string EncodeSource(string source)
        => Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(source))
            .TrimEnd('=')
            .Replace('+', '-')
            .Replace('/', '_');

    private static bool TryDecodeSource(string encodedSource, out string source)
    {
        source = string.Empty;
        if (encodedSource.Length > 128_000)
            return false;

        var base64 = encodedSource.Replace('-', '+').Replace('_', '/');
        switch (base64.Length % 4)
        {
            case 2:
                base64 += "==";
                break;
            case 3:
                base64 += "=";
                break;
            case 1:
                return false;
        }

        try
        {
            source = new System.Text.UTF8Encoding(false, true)
                .GetString(Convert.FromBase64String(base64));
            return true;
        }
        catch (Exception exception) when (
            exception is FormatException or
                System.Text.DecoderFallbackException)
        {
            return false;
        }
    }

    private static bool TryGetQueryParameter(Uri uri, string name, out string value)
    {
        try
        {
            foreach (var item in uri.Query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries))
            {
                var parts = item.Split('=', 2);
                if (!string.Equals(Uri.UnescapeDataString(parts[0]), name, StringComparison.Ordinal))
                    continue;

                value = parts.Length == 2 ? Uri.UnescapeDataString(parts[1]) : string.Empty;
                return true;
            }
        }
        catch (UriFormatException)
        {
        }

        value = string.Empty;
        return false;
    }

    private sealed record PlaygroundExampleEntry(string Id, string Title, string File);

    private async Task CompileCoreAsync(bool run)
    {
        if (_isBusy || _editor is null)
            return;

        _isBusy = true;
        _status = "Compiling";
        _output = string.Empty;
        _diagnostics = [];

        try
        {
            var source = await _editor.InvokeAsync<string>("getValue");
            await Task.Yield();
            var compilation = LanguageService.Compile(source);
            _diagnostics = compilation.Diagnostics;

            if (!compilation.Success || compilation.AssemblyImage is null)
            {
                _status = "Compile error";
                _output = "Compilation failed.";
                return;
            }

            if (!run)
            {
                _status = "Compiled";
                _output = $"Compiled successfully ({compilation.AssemblyImage.Length:N0} bytes).";
                return;
            }

            _status = "Running";
            await Task.Yield();
            var execution = await Runner.RunAsync(compilation.AssemblyImage);
            _status = "Complete";
            _output = string.IsNullOrEmpty(execution.Output)
                ? $"Program exited with code {execution.ExitCode}."
                : execution.Output;
        }
        catch (Exception exception)
        {
            _status = run ? "Runtime error" : "Compile error";
            _output = exception.ToString();
        }
        finally
        {
            _isBusy = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_editor is not null)
            await _editor.InvokeVoidAsync("dispose");
        if (_module is not null)
            await _module.DisposeAsync();
        _commandTarget?.Dispose();
    }
}
