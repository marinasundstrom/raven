func Divide(total: int, people: int) -> Result<int, string> {
    if people == 0 {
        return Error("The group cannot be empty")
    }

    return Ok(total / people)
}

match Divide(42, 6) {
    Ok(let share) => Console.WriteLine("Each person gets $share")
    Error(let message) => Console.WriteLine("Problem: $message")
}
