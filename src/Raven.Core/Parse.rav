namespace System

import System.*
import System.Globalization.*
import System.Option.*
import System.Result.*
import System.Runtime.CompilerServices.*

extension Int32Extensions for Int32 {

    [FrameworkProjection("system.int32.tryparse.string.option.v1")]
    static func TryParse(input: string?) -> Option<int> {
        if Int32.TryParse(input, out var value) {
            return Some(value)
        }

        return None
    }

    [FrameworkProjection("system.int32.tryparse.string-style-provider.option.v1")]
    static func TryParse(input: string?, style: NumberStyles, provider: IFormatProvider?) -> Option<int> {
        if Int32.TryParse(input, style, provider, out var value) {
            return Some(value)
        }

        return None
    }

    [FrameworkProjection("system.int32.parse.string.result.v1")]
    static func Parse(input: string) -> Result<int, Union<ArgumentNullException, FormatException, OverflowException>> {
        try {
            return Ok(int.Parse(input))
        } catch ArgumentNullException ex {
            return Error(ex)
        } catch FormatException ex {
            return Error(ex)
        } catch OverflowException ex {
            return Error(ex)
        }
    }
}

