import System.Console.*

func Main() -> () {
    let value = Run()
    WriteLine(value)

    let value2 = Run2()
    WriteLine(value2)
}

unsafe func Run() -> int {
    let holder = Holder()
    let pointer: *Holder = &holder
    return pointer->Value
}

unsafe func Run2() -> int {
    let value = 41
    let pointer: *int = &value
    *pointer = 42
    return value
}

struct Holder {
    field Value: int = 42
}
