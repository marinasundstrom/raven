import System.*
import System.Console.*
import System.Linq.*

func Main(args: string[]) -> () {
    WriteLine(args.Length)

    let r = typeof(String)
    WriteLine(r)

    let members = r.GetMembers(.Public | .Static)

    let name = "Intern"

    for member in members.Where(x => x.Name.Equals(name)) {
        WriteLine(member.Name)
    }

    let result = members.FirstOrNone()

    if(result is Some(let member)) {
        WriteLine("First: $member")
    }
}