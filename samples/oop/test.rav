import System.*
import System.Console.*

val customer = Customer("Acme", 20)
val customer2 = Customer("Marina")

PrintCustomer(customer)
PrintCustomer(customer2)

func PrintCustomer(customer: Customer) {
    WriteLine("${customer.Name} age: ${customer.Age ?? "n/a"} score: ${customer.Score}")
}

class Customer(name: string, age: int? = null) {
    {
        if name is "Marina" {
            Score = 100
        } else {
            Score = 0
        }
    }

    val Name: string => name

    val Age: int? => age

    val Score: int { get; }

    func Anonymize() {
        //name = ""
    }
}
