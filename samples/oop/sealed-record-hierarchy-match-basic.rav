import System.*
import System.Console.*

// Feature: sealed record hierarchy evaluated via `match`.
let expr: Expr = Add(Lit(40), Sub(Lit(3), Lit(1)))

Evaluate(expr) |> WriteLine

func Evaluate(expr: Expr) -> int {
    match expr {
        Lit(let value) => value
        Add(let left, let right) => Evaluate(left) + Evaluate(right)
        Sub(let left, let right) => Evaluate(left) - Evaluate(right)
        Mul(let left, let right) => Evaluate(left) * Evaluate(right)
        Div(let left, let right) => Evaluate(left) / Evaluate(right)
    }
}

sealed record Expr
record Lit(Value: int) : Expr
sealed record BinaryExpr(Left: Expr, Right: Expr) : Expr
record Add(Left: Expr, Right: Expr) : BinaryExpr(Left, Right)
record Sub(Left: Expr, Right: Expr) : BinaryExpr(Left, Right)
record Mul(Left: Expr, Right: Expr) : BinaryExpr(Left, Right)
record Div(Left: Expr, Right: Expr) : BinaryExpr(Left, Right)
