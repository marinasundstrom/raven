import System.*

// Feature: event subscription and unsubscription (`+=`, `-=`).
let f: IFoo = Foo()

f.Raised += (s, e) => Console.WriteLine("Hello");

let handler: EventHandler = (s: object?, e: EventArgs) => Console.WriteLine("Hello");

f.Raised += handler

let x = f.RaiseEvent(2)

f.Raised -= handler

f.RaiseEvent(3)

interface IFoo {
    func RaiseEvent(x: int) -> int

    event Raised: EventHandler?
}

class Foo : IFoo {
    func RaiseEvent(x: int) -> int {
        Raised?(self, EventArgs.Empty)
        return 42
    }

    event Raised: EventHandler?
}
