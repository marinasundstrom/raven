import System.Console.*

// Feature: with-expression on records.
val bob = Person("Bob", null, "Smith", 1978)
WriteLine(bob)

val newBob = bob with {
    MiddleName = "Leslie"
}

WriteLine(newBob)

val renamed = newBob with {
    MiddleName = "Flash",
    LastName = "Jones"
}

WriteLine(renamed)

record class Person(Name: string, MiddleName: string?, LastName: string, YearOfBirth: int)
