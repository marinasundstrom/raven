import System.Console.*

// Feature: property override compatibility across base references.
let writable: Base = D1()
let readableOnly: Base = D2()

writable.P = 3
WriteLine(writable.P)

let current = readableOnly.P
WriteLine(current)
// readableOnly.P = 4  // Not allowed: setter is not common on all subtypes.

open class Base { virtual var P: int { get; set; } = 0 }
class D1 : Base { override var P : int { get; set; } = 0 }
class D2 : Base { override val P : int { get; } = 0 }
