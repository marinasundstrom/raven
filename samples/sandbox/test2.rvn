import System.*
import System.Console.*
import System.Collections.Generic.*
import System.Text.Json.*
import System.IO.*
import System.Threading.Tasks.*

val builder = WebAppBuilder()
builder.MapPost("/", async (arg: string) -> Task<HttpResult<()>> => {
    await Task.Delay(200)
    return .Created
})

union HttpResult<T> {
    case Ok
    case Created
    case BadRequest
}

class WebAppBuilder {
    val routes = List<string>()

    func MapPost(path: string, d: Delegate) -> () {
        routes.Add(path)
        WriteLine("Route ${routes.Count}: $path")

        val invoke = d.Method
        WriteLine("${invoke.Name} -> ${invoke.ReturnType}")
        for param in invoke.GetParameters() {
            WriteLine("${param.Name}: ${param.ParameterType}")
        }
    }
}

