import System.*
import System.Console.*
import System.Collections.Generic.*
import System.Linq.*

let r: Option<int> = Some(42)
let w = match r {
    Some(let x) => Option<int>.Some(x * 2)
    None => None
}

WriteLine(w)
WriteLine(tap(r))
WriteLine(inferLabel(1))

for x in [1, 2, 3] {
    WriteLine(x)
}

for x in r {
    WriteLine(x)
}

func tap(value: Option<int>) -> Option<int> {
    if value is Some(let x) {
        WriteLine(x)
    }
    return match value {
        Some(let x) => Some(x)
        None => None
    }
}

func inferLabel(x: int) -> string {
    if x > 0 { return "gt0" }
    "le0"
}
