import System.Console.*

// Feature: `for` loop over a collection.
val orders = [
    Order(1001, 120)
    Order(1002, 80)
    Order(1003, 45)
    Order(1004, 210)
]
var totalPending = 0

for val (id, amount) in orders {
    totalPending = totalPending + amount
    WriteLine("Queued order $id amount: $amount")
}

WriteLine("Total pending amount: $totalPending")

record Order(
    val Id: int, 
    val Amount: int
)
