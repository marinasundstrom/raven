import System.*
import System.Console.*
import System.Threading.Tasks.*

// Feature: async Result propagation on the error path.
let res = await test()

let str = match res {
    Ok(let str) => "Response is: $str"
    Error(let message) => "Error is: $message"
}

WriteLine(str)

async func test() -> Task<Result<string, Exception>> {
    let r = try? await failingTask2()
    return Ok("foo")
}

async func failingTask2() -> Task<Result<string, Exception>> {
    await Task.Delay(20)
    throw Exception("Boom!")
    return Ok("test")
}
