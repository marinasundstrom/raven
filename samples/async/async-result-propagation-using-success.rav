import System.*
import System.Console.*
import System.Net.Http.*
import System.Threading.Tasks.*

// Feature: async Result propagation with a successful `use` resource flow.
let res = await fetch("http://www.contoso.com/")

let str = match res {
    Ok(let str) => "Response is: $str"
    Error(let exception) => "Error is: ${exception.Message}"
}

WriteLine(str)

async func fetch(url: string) -> Task<Result<string, Exception>> {
    use client = HttpClient()
    let response = try? await client.GetAsync(url)
    let responseBody = await response.Content.ReadAsStringAsync()
    return Ok(responseBody)
}
