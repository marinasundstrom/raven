import System.*
import System.Console.*
import System.Reactive.*
import System.Reactive.Subjects.*
import System.Reactive.Linq.*

func Main() {
    val viewModel = CounterViewModel()

    use subscription = #subscribe(viewModel.Count, func (value) => {
        WriteLine(value)
    })

    viewModel.Count = 1
    viewModel.Count = 1
    viewModel.Count = 2
}

class CounterViewModel {
    #[Observable]
    var Count: int = 0
}
