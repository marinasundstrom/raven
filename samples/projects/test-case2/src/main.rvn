import System.*
import System.Console.*

var people = [
    Person("Alice", 25, [ "Horse", "Saddle" ])
    Person("John", 18, [ "Keys", "Wallet" ])
    Person("Jane", 15, [ "Sunglasses", "Purse" ])
]

people = people.Add(Person("Test", 30, ["A", "B"]))

for val (name, age when > 15, [ item1, item2 ]) in people {
    WriteLine("$name ($age) has $item1 and $item2")
}

record Person(
    val Name: string
    val Age: int
    val Items: string[]
)