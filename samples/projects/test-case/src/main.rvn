import System.*
import System.Console.*

func Main() {
    var a = 1, b = 2
    WriteLine("a: $a, b: $b")
    
    (b, a) = (a, b)
    WriteLine("a: $a, b: $b")

    Tuple()
    Person()

    val arr = [3, 9, 10, 3, 2]
    val [first, second, ...rest] = arr

    WriteLine("first: $first, and second: $second")

    for no in rest {
        WriteLine(no)
    }

    val str = "FooBar42"
    val [ch, ..2 start, ...end] = str

    WriteLine("ch: $ch, start: $start, and end: $end")

    val points = [(2, 3), (2, 0), (5, 1)]
    for (val x, 0) in points {
        WriteLine(x)
    }

    val persons = [Person(1, "John Doe", 20)]
    for Person(1, val name, _) in persons {
        WriteLine(name)
    }
}

func Tuple() {
    val person = (no: 1, name: "John Doe")
    val (id, name) = person

    WriteLine("$id: $name")
}

func Person() {
    val person = Person(1, "John Doe", 20)
    val (id, name, _) = person

    WriteLine("$id: $name")
}

record Person(
    val Id: int, 
    val Name: string, 
    val Age: int
)