import System.*
import System.Console.*
import System.Collections.Generic.*
import System.Collections.Immutable.*
import System.Linq.*

func Main() {
    RunExistingPatternExamples()
    RunCollectionPatternExamples()
    RunCollectionComprehensionExamples()
}

func RunExistingPatternExamples() {
    var a = 1, b = 2
    PrintSection("Swap assignment")
    WriteLine("Before swap: a = $a, b = $b")

    (b, a) = (a, b)
    WriteLine("After swap:  a = $a, b = $b")

    var e1 = 0, e2 = 0, e3 = 0
    PrintSection("Sequence assignment")
    [e1, e2, e3] = [3, 9, 10]
    WriteLine("Bound from [3, 9, 10] -> e1 = $e1, e2 = $e2, e3 = $e3")

    PrintSection("Tuple and nominal deconstruction")
    Tuple()
    Person()
    Person2()

    val arr = [3, 9, 10, 3, 2]
    val [first, second, ...rest] = arr

    PrintSection("Sequence declaration")
    WriteLine("Input:  ${DescribeInts(arr)}")
    WriteLine("Bound: first = $first, second = $second, rest = ${DescribeInts(rest)}")

    for no in rest {
        WriteLine("rest item -> $no")
    }

    val str = "FooBar42"
    val [ch, ..2 start, ...end] = str

    PrintSection("String sequence segments")
    WriteLine("Input:  \"$str\"")
    WriteLine("Bound: ch = '$ch', start = \"$start\", end = \"$end\"")

    val points = [(2, 3), (2, 0), (5, 1)]
    PrintSection("for pattern")
    for val (x, > 0) in points {
        WriteLine("Matched a point with y > 0; bound x = $x")
    }

    val persons = [Person(1, "John Doe", 20)]
    for val Person(1, name, _) in persons {
        WriteLine("Matched Person(1, name, _); bound name = $name")
    }

    val point = (5, 1)
    PrintSection("if pattern")
    if val (x, 1) = point {
        WriteLine("Matched ${DescribePoint(point)} with (x, 1); bound x = $x")
    }

    if val (5, > 0) p = point {
        WriteLine("Matched (5, > 0); whole designation p = ${DescribePoint(p)}")
    }

    if val (x0 when == 5, y0 when > 0) = point {
        WriteLine("Matched ${DescribePoint(point)} with (x when == 5, y when > 0); bound x = $x0 and y = $y0")
    }

    val person = Person(1, "John Doe", 20)
    if val Person(1, name, _) = person {
        WriteLine("Matched ${DescribePerson(person)} with Person(1, name, _); bound name = $name")
    }

    val arr2 = [3, 9, 10, 3, 2]
    if val [first2, second2, ...rest2] = arr2 {
        WriteLine("Matched ${DescribeInts(arr2)} with [first2, second2, ...rest2]")
        WriteLine("Bound: first2 = $first2, second2 = $second2, rest2 = ${DescribeInts(rest2)}")
    }
}

func RunCollectionPatternExamples() {
    PrintSection("Collection spread and declaration")

    val spreadSource = [|1, 2, 3|]
    val spreadArray = [|1, ...spreadSource, 3|]

    val [first, second, ...] = spreadArray
    WriteLine("Input:  ${DescribeInts(spreadSource)}")
    WriteLine("Spread: ${DescribeInts(spreadArray)}")
    WriteLine("Bound: first = $first, second = $second")

    PrintSection("Collection range iteration")
    WriteLine("Input:  [2, 1..2]")
    for value in [2, 1..2] {
        WriteLine("item -> $value")
    }

    PrintSection("Collection segment pattern")
    for val [..2, ..2 segment, ...] in [[|2, 1..4|]] {
        WriteLine("Matched [|2, 1..4|] with [..2, ..2 segment, ...]")
        WriteLine("Bound: segment = ${DescribeInts(segment)}")
    }

    val dict = ["a": 1, "b": 2, "c": 3]
    val dict2 = ["e": 5, ...dict]

    PrintSection("Dictionary spread")
    WriteLine("Source:")
    for val (key, value) in dict {
        WriteLine("$key: $value")
    }
    WriteLine("Spread result:")
    for val (key, value) in dict2 {
        WriteLine("$key: $value")
    }

    PrintSection("Dictionary pattern")
    val ["e": entry] = dict2
    WriteLine("Bound from [\"e\": entry] -> entry = $entry")

    if val ["c": existing] = dict2 {
        WriteLine("Matched [\"c\": existing]; bound existing = $existing")
    }
}

func RunCollectionComprehensionExamples() {
    PrintSection("Collection comprehensions")

    val numbers = [|1, 2, 3, 4, 5|]
    val squares = [for n in numbers => n * n]
    val evenSquares = [for n in numbers if n % 2 == 0 => n * n]
    val rangeValues = [for n in 3..<7 => n]

    WriteLine("Input numbers: ${DescribeInts(numbers)}")
    WriteLine("Squares:       ${DescribeInts(squares)}")
    WriteLine("Even squares:  ${DescribeInts(evenSquares)}")
    WriteLine("Range values:  ${DescribeInts(rangeValues)}")

    val mutableSquares = ![for n in numbers => n * 10]
    WriteLine("Mutable form:  ${DescribeInts(mutableSquares)}")

    PrintSection("Dictionary comprehensions")

    val lengths = [for text in [|"a", "bb", "ccc"|] => text: text.Length]
    WriteLine("Lengths:")
    for val (key, value) in lengths {
        WriteLine("$key: $value")
    }

    PrintSection("Pattern comprehensions")

    val people = [(1, "Ada"), (2, "Bob"), (2, "Eve")]
    val selectedNames = [for val (2, name) in people => name]
    WriteLine("Selected names: ${DescribeStrings(selectedNames)}")

    val pairs = [("one", 1), ("two", 2), ("three", 3)]
    val doubled = [for val (key, value) in pairs if value >= 2 => key: value * 2]
    WriteLine("Doubled dictionary:")
    for val (key, value) in doubled {
        WriteLine("$key: $value")
    }
}

func Tuple() {
    val person = (no: 1, name: "John Doe")
    val (id, name) = person

    WriteLine("Tuple deconstruction -> id = $id, name = $name")
}

func Person() {
    val person = Person(1, "John Doe", 20)
    val (id, name, _) = person

    WriteLine("Nominal deconstruction -> id = $id, name = $name")
}

func Person2() {
    val people = [
        Person2("Alice", 25, [ "Horse", "Saddle" ])
        Person2("John", 18, [ "Keys", "Wallet" ])
        Person2("Jane", 15, [ "Sunglasses", "Purse" ])
    ]

    for val (name, age when > 15, [ item1, item2 ]) in people {
        WriteLine("Nested deconstruction -> $name ($age) has $item1 and $item2")
    }
}

func PrintSection(title: string) {
    WriteLine("")
    WriteLine("== $title ==")
}

func DescribeInts(values: IEnumerable<int>) -> string {
    var text = "["
    var isFirst = true

    for value in values {
        if !isFirst {
            text = text + ", "
        }

        text = text + value.ToString()
        isFirst = false
    }

    return text + "]"
}

func DescribePoint(point: (int, int)) -> string {
    return "(${point.Item1}, ${point.Item2})"
}

func DescribeStrings(values: IEnumerable<string>) -> string {
    var text = "["
    var isFirst = true

    for value in values {
        if !isFirst {
            text = text + ", "
        }

        text = text + value
        isFirst = false
    }

    return text + "]"
}

func DescribePerson(person: Person) -> string {
    return "Person(Id: ${person.Id}, Name: ${person.Name}, Age: ${person.Age})"
}

record Person(
    val Id: int,
    val Name: string,
    val Age: int
)

record Person2(
    val Name: string
    val Age: int
    val Items: string[]
)
