import System.*
import System.Console.*

func Main() {
    var a = 1, b = 2
    WriteLine("a: $a, b: $b")
    
    (b, a) = (a, b)
    WriteLine("a: $a, b: $b")

    var e1 = 0, e2 = 0, e3 = 0
    [e1, e2, e3] = [3, 9, 10]
    WriteLine("e1: $e1, e2: $e2, e3: $e3")

    Tuple()
    Person()

    val arr = [3, 9, 10, 3, 2]
    val [first, second, ...rest] = arr

    WriteLine("first: $first, and second: $second")

    for no in rest {
        WriteLine(no)
    }

    val str = "FooBar42"
    val [ch, ..2 start, ...end] = str

    WriteLine("Matched pattern [ch, ..2 start, ...end] with ch = $ch, start = $start, and end = $end")

    val points = [(2, 3), (2, 0), (5, 1)]
    for val (x, > 0) in points {
        WriteLine("Matched pattern (x, > 0) with x = $x")
    }

    val persons = [Person(1, "John Doe", 20)]
    for val Person(1, name, _) in persons {
        WriteLine("Matched pattern Person(1, name, _) with name = $name")
    }

    val point = (5, 1)
    if val (x, 1) = point {
        WriteLine("Matched pattern (x, 1) with x = $x")
    }

    if val (5, > 0) p = point {
        WriteLine("Matched pattern (5, > 0) as p = $p")
    }

    val person = Person(1, "John Doe", 20)
    if val Person(1, name, _) = person {
        WriteLine("Matched pattern Person(1, name, _) with name = $name")
    }

    val arr2 = [3, 9, 10, 3, 2]
    if val [first2, second2, ...rest2] = arr2 {
        WriteLine("Matched pattern [first2, second2, ...rest2] with first2 = $first2, second2 = $second2, rest2 having ${rest2.Length} elements")
    }
}

func Tuple() {
    val person = (no: 1, name: "John Doe")
    val (id, name) = person

    WriteLine("$id: $name")
}

func Person() {
    val person = Person(1, "John Doe", 20)
    val (id, name, _) = person

    WriteLine("$id: $name")
}

record Person(
    val Id: int, 
    val Name: string, 
    val Age: int
)