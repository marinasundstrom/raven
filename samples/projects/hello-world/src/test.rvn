namespace Utilities

import System.Console.*

func getTemperature() -> Result<Temperature, TemperatureError> {
    if let Ok(no) = int.parse("42") {
        return Ok(Temperature(no))
    }
    return Error(TemperatureError("Unable to fetch temperature"))
}

func Test2() -> IDisposable {
    return Disposable()
}

class Disposable : IDisposable {
    func Dispose() {}
}
