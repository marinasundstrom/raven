import Utilities.*

func Main() {
    Test()
    val x = A(42)
    Test()
    A(x)
    A("42")

    use test = Test2()
    test?.Dispose() // ? Shouldn't be valid on non-nullable type. And hovering "Dispose" after "?."" don't display hint.

    val v: Foo = 3
    val r = v match {
        int i => i
        string => 2
        _ => 4
    }

    Console.WriteLine(r)

    val s = Status.Open("foo")
    match s {
        .Open(val reason) => Console.WriteLine("Reason $reason")
        .Closed(_) => ()
    }

    if let Ok(no) = int.parse("42") {
        Console.WriteLine(no)
    }
}

union Foo(int | string | null)

union Status {
    case Closed(reason: string)
    case Open(reason: string)
}