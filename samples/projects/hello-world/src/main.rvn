import Utilities.*

func Main() {
    val s = Status.Open("foo")
    match s {
        .Open(val reason) => Console.WriteLine("Reason $reason")
        .Closed(_) => ()
    }

    if let Ok(temp) = getTemperature() {
        Console.WriteLine(temp.Value)
    }
}

record Temperature(val Value: double)

record TemperatureError(val Message: string)

union Status {
    case Closed(reason: string)
    case Open(reason: string)
}
