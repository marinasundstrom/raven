import System.*

val showSecondary = true
val status = UiLabel("Ready")

RunApp(Window {
    Title = "Tasks"

    StackPanel {
        Spacing = 8.0

        Label("Inbox")

        if showSecondary {
            Label("Today")
        }

        status

        Button("Add") {
            status.SetContent("Clicked Add")
            Console.WriteLine("Clicked Add")
        }
    }
})
