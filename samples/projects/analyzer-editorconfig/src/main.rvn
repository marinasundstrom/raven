import System.Linq.*
import System.*

func ReadName(input: string?) -> string {
    let name = input ?? throw Exception("Name is required")
    return name
}

func Main() {
    // Classic nullable style instead of Option<T>.
    let maybeAge: int? = null

    // Regular LINQ instead of Result/Option extensions.
    let values = [1, 2, 3]
    let first = values.FirstOrDefault()

    _ = maybeAge
    _ = first

    let name = ReadName("Raven")
    Console.WriteLine(name)
}
