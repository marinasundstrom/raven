import System.*
import System.Console.*
import System.Collections.Generic.*
import System.Collections.Immutable.*
import System.Linq.*

func Main() {
    val arr1 = [|1, 2, 3|]
    val arr2 = [|1, ...arr1, 3|]

    val [a, b, ...] = arr2

    for x in [2, 1..2] {
        WriteLine(x)
    }

    for val [..2, ..2 x, ...] in [[|2, 1..4|]] {
        WriteLine(x)
    }

    val dict = ["a": 1, "b": 2, "c": 3]
    val dict2 = ["e": 5, ...dict]

    for keyValue in dict2 {
        WriteLine(keyValue)
    }

    for val (key, value) in dict2 {
        WriteLine("$key: $value")
    }
}