import System.*
import System.Console.*
import System.Net.Http.*
import System.Threading.Tasks.*

let res1 = await test("42", throwExc: false)
WriteLine(res1)

let res2 = await test("42", throwExc: true)
WriteLine(res2)

let res3 = await test("foo", throwExc: false)
WriteLine(res3)

let res4 = await test("foo", throwExc: true)
WriteLine(res4)

async func test(text: string, throwExc: bool) -> Task<Result<int, Exception>> {
    let str = try? await action(text, throwExc)
    let x = try? Convert.ToInt32(str)
    WriteLine(x)
    return Ok(x + 2)
}

async func action(text: string, throwExc: bool) -> Task<Result<string, Exception>> {
    await Task.Delay(200)
    if throwExc {
        throw Exception("Boom!")
    }
    return Ok(text)
}
