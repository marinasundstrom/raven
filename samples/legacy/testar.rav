
import System.*

let test: Result<int, string> = Ok(42)

let x = match test {
    Ok(42) => "Answer is 42"
    Ok(let no) => "Other no: $no"
    Error(let msg) => msg
}

Console.WriteLine(x)

if test is Ok(42) {
    Console.WriteLine("42")
}

if test is Ok(let value) {
    Console.WriteLine("Value is: $value")
}