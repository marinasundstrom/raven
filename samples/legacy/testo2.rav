import System.*
import System.Console.*

ping("bob")

func ping(name: string) -> Result<PingResult, CustomError> {
    match name {
        "Bob" | "bob" => return Ok(PingResult("pong ${name}"))
        _ => return Error(CustomError("Invalid name"))
    }
}

record class PingResult(Message: string)

record class CustomError(Message: string)