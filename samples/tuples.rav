val tuple2 : (id: int, name: string) = (42, "Bar")

val name = tuple2.name

val r = tuple2 match {
    (42, val b: string) => "tuple 42 $b"
    (val a: int, val b: string) => "tuple $b"
    //_ => "none"
}

System.Console.WriteLine(r)
