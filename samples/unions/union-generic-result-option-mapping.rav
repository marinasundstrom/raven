import System.*

// Feature: mapping generic union cases into `Option`.
let ok : Result<int, string> = .Ok(99)
let err = Result<int, string>.Error("boom")

Console.WriteLine(format(ok))
Console.WriteLine(format((Result<int, string>)err))

func format<T>(result: Result<T, string>) -> Option<string> {
    match result {
        Ok(let value) => value.ToString()
        Error(_) => None
    }
}
