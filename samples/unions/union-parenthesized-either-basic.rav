import System.*
import System.Console.*

// Feature: parenthesized generic union declaration over existing types.
PrintPaymentSource(42)
PrintPaymentSource("invoice")

func PrintPaymentSource(value: Either<int, string>) {
    WriteLine(value)

    let description = match value {
        int amount => "cash $amount"
        string reference => "card $reference"
    }

    WriteLine(description)
}

union Either<T1, T2>(T1 | T2)
