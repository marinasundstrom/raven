import System.Console.*

// Feature: parenthesized union declaration over existing nominal member types.
PrintPaymentSource(Cash(42.0m))

func PrintPaymentSource(value: Payment) {
    WriteLine(value)

    let description = match value {
        Cash(let amount) => "cash $amount"
        Card(let reference) => "card $reference"
    }

    WriteLine(description)
}

record Cash(Amount: decimal)
record Card(Reference: string)

union Payment(Cash | Card)

PrintPaymentSource(Card("invoice"))
