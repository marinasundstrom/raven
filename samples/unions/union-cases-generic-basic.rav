import System.Console.*

// Feature: basic discriminated union cases (non-generic + generic).
val x: Test1 = .A(42)
val x2: Test2<int> = .A(42)

WriteLine(x)
WriteLine(x2)

func test1() -> Test1 {
    return .A(42)
}

func test2() -> Test2<int> {
    return .A(42)
}

WriteLine(test1())
WriteLine(test2())

union Test1 {
    case A(x: int)
    case B
}

union Test2<T> {
    case A(value: T)
    case B
}
