import System.Console.*

// Feature: multiline string interpolation forms.
// Normal multiline string literal
let test = """
    test
        32
    """

WriteLine(test)

let text = "Hi!"

// Multiline string literal with interpolation
let bb = """
    test ${41 + 1}
      r ${text}
    """

WriteLine(bb)

    // Multiline string literal with interpolation
let bc = """
    test ${41 + 1}
      r $text
    """

WriteLine(bc)
