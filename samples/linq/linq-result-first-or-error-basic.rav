import System.*
import System.Console.*
import System.Collections.Generic.*
import System.Linq.*

// Feature: LINQ `FirstOrError` extension in its simplest form.
val pendingShipments = [101, 202, 303]

val selected = pendingShipments.FirstOrError(() => DomainError.NotFound)

WriteLine(selected)

union DomainError {
    NotFound
    Unexpected(exception: Exception)
}
