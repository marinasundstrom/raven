import System.*

// Feature: `match` over nullable values returning `Result`.
Console.WriteLine(f())

func f() -> Result<int, Err> {
    let len: int? = null

    match len {
        null       => Error(.MissingName)
        let value  => Ok(value ?? 0)
    }
}

union Err {
    case MissingUser
    case MissingName
}
