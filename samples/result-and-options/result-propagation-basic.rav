import System.*
import System.Console.*

// Feature: `Result` propagation with `?`.
let x = match test() {
    Ok(let y) => "Foo: $y"
    Error(let exc) => "Error: ${exc.Message}"
}

WriteLine(x)

func test() -> Result<int, Exception> {
    let r = test2(4)?
    WriteLine(r)
    return Ok(r + 1)
}

func test2(i: int) -> Result<int, Exception> {
    if i != 3 {
        return Error(Exception("Bang!"))
    }
    return Ok(42)
}
