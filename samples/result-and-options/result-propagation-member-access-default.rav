import System.*

// Feature: member access propagation plus `UnwrapOrDefault`.
Console.WriteLine(f())

func GetUser() -> Result<User, Err> {
    // sample implementation
    return Ok(User("Marina"))
}

func f() -> Result<int, Err> {
    let wrapped = GetUser()?.Name // Result<string, Err>

    let str = wrapped.UnwrapOrDefault()

    return Ok(str.Length + 1)
}

union Err {
    case MissingUser
    case MissingName
}

record class User(Name: string)
