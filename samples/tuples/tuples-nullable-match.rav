import System.Console.*
import System.*

// Feature: tuple pattern matching with optional tuple value.
let status: Option<(isPriority: bool, carrier: string)> = Some((false, "BlueShip"))

let result = match status {
    Some((let isPriority, let carrier)) => "Priority=${isPriority}, Carrier=${carrier}"
    None => "No shipping status"
}

WriteLine(result)
