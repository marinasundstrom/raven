import System.Console.*

// Feature: fixed-size and rest sequence segment patterns for arrays and strings.

let values: int[] = [2, 3, 4]
let [..2 start, last] = values

let text = "rune"

let label = match text {
    [let first, ..2 let middle, let lastChar] => first.ToString() + "-" + middle + "-" + lastChar.ToString()
    _ => "no-match"
}

WriteLine((start[0] + start[1] + last).ToString())
WriteLine(label)
