import System.Console.*

// Feature: expression-form `match` producing a value.
let orderId = 1001
let statusPayload: object = "paid"
let paidCode = "paid"

let label = match statusPayload {
  paidCode => "Invoice cleared"
  string code => "Unknown string status: ${code}"
  _ => "Non-string status"
}

WriteLine("Order ${orderId}: ${label}")
