<Project>
  <PropertyGroup>
    <RavenCompilerProject Condition="'$(RavenCompilerProject)' == ''">$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\src\Raven.Compiler\Raven.Compiler.csproj'))</RavenCompilerProject>
    <RavenCompilerFramework Condition="'$(RavenCompilerFramework)' == ''">net10.0</RavenCompilerFramework>
    <RavenCompilerHost Condition="'$(RavenCompilerHost)' == ''">$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\src\Raven.Compiler\bin\Debug\$(RavenCompilerFramework)\rvn.dll'))</RavenCompilerHost>
    <RavenProjectFile Condition="'$(RavenProjectFile)' == ''">$([System.IO.Path]::Combine('$(MSBuildProjectDirectory)',
      '$(MSBuildProjectName).ravenproj'))</RavenProjectFile>
    <RavenOutputDir Condition="'$(RavenOutputDir)' == ''">$([System.IO.Path]::Combine('$(MSBuildProjectDirectory)',
      'obj', 'raven'))</RavenOutputDir>
    <RavenBuildArgs Condition="'$(RavenBuildArgs)' == ''"></RavenBuildArgs>
    <RavenAssemblyName Condition="'$(RavenAssemblyName)' == ''">
      $([System.IO.Path]::GetFileNameWithoutExtension('$(RavenProjectFile)'))</RavenAssemblyName>
    <RavenAssemblyPath Condition="'$(RavenAssemblyPath)' == ''">$([System.IO.Path]::Combine('$(RavenOutputDir)',
      '$(RavenAssemblyName).dll'))</RavenAssemblyPath>
  </PropertyGroup>

  <ItemGroup Condition="Exists('$(RavenProjectFile)')">
    <Reference Include="$(RavenAssemblyName)">
      <HintPath>$(RavenAssemblyPath)</HintPath>
      <Private>true</Private>
    </Reference>
  </ItemGroup>

  <Target Name="BuildRavenProject"
    BeforeTargets="ResolveReferences"
    Condition="Exists('$(RavenProjectFile)')">
    <MakeDir Directories="$(RavenOutputDir)" />
    <Error
      Condition="!Exists('$(RavenCompilerHost)')"
      Text="Built Raven compiler host not found at '$(RavenCompilerHost)'. Build Raven.Compiler first." />

    <Exec
      Command="dotnet &quot;$(RavenCompilerHost)&quot; &quot;$(RavenProjectFile)&quot; -o &quot;$(RavenOutputDir)&quot; --framework &quot;$(RavenCompilerFramework)&quot; $(RavenBuildArgs)" />

  </Target>

  <Target Name="BuildRavenProjectMissing"
    BeforeTargets="ResolveReferences"
    Condition="!Exists('$(RavenProjectFile)') and '$(RavenProjectFile)' != ''">
    <Warning
      Text="Raven project file was not found at '$(RavenProjectFile)'. Set &lt;RavenProjectFile&gt; in the importing .csproj." />
  </Target>
</Project>
