<Project>
  <PropertyGroup>
    <RavenCompilerFramework Condition="'$(RavenCompilerFramework)' == '' and '$(TargetFramework)' == 'net11.0'">net11.0</RavenCompilerFramework>
    <RavenCompilerFramework Condition="'$(RavenCompilerFramework)' == ''">net10.0</RavenCompilerFramework>
    <RavenBuildConfiguration Condition="'$(RavenBuildConfiguration)' == '' and '$(Configuration)' != ''">$(Configuration)</RavenBuildConfiguration>
    <RavenBuildConfiguration Condition="'$(RavenBuildConfiguration)' == ''">Debug</RavenBuildConfiguration>
    <RavenSdkRoot Condition="'$(RavenSdkRoot)' == '' and Exists('$(MSBuildThisFileDirectory)..\..\VERSION')">$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\..'))</RavenSdkRoot>
    <RavenCompilerHost Condition="'$(RavenCompilerHost)' == '' and '$(RavenSdkRoot)' != '' and Exists('$(RavenSdkRoot)\tools\rvnc\rvnc.dll')">$(RavenSdkRoot)\tools\rvnc\rvnc.dll</RavenCompilerHost>
    <RavenCompilerHost Condition="'$(RavenCompilerHost)' == '' and Exists('$(MSBuildThisFileDirectory)..\tools\$(RavenCompilerFramework)\rvnc.dll')">$(MSBuildThisFileDirectory)..\tools\$(RavenCompilerFramework)\rvnc.dll</RavenCompilerHost>
    <RavenCompilerHost Condition="'$(RavenCompilerHost)' == ''">$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\src\Raven.Compiler\bin\$(RavenBuildConfiguration)\$(RavenCompilerFramework)\rvnc.dll'))</RavenCompilerHost>
    <RavenCoreTargetFrameworkCandidate Condition="'$(TargetFramework)' != ''">$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\src\Raven.Core\bin\$(RavenBuildConfiguration)\$(TargetFramework)\Raven.Core.dll'))</RavenCoreTargetFrameworkCandidate>
    <RavenCoreCompilerFrameworkCandidate>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\src\Raven.Core\bin\$(RavenBuildConfiguration)\$(RavenCompilerFramework)\Raven.Core.dll'))</RavenCoreCompilerFrameworkCandidate>
    <RavenCompilerHostDirectory>$([System.IO.Path]::GetDirectoryName('$(RavenCompilerHost)'))</RavenCompilerHostDirectory>
    <RavenCoreCompilerHostCandidate>$([System.IO.Path]::Combine('$(RavenCompilerHostDirectory)', 'Raven.Core.dll'))</RavenCoreCompilerHostCandidate>
    <RavenCoreReferencePath Condition="'$(RavenCoreReferencePath)' == '' and '$(RavenSdkRoot)' != '' and Exists('$(RavenSdkRoot)\sdk\Raven.Core.dll')">$(RavenSdkRoot)\sdk\Raven.Core.dll</RavenCoreReferencePath>
    <RavenCoreReferencePath Condition="'$(RavenCoreReferencePath)' == '' and '$(TargetFramework)' != '' and Exists('$(MSBuildThisFileDirectory)..\tools\$(TargetFramework)\Raven.Core.dll')">$(MSBuildThisFileDirectory)..\tools\$(TargetFramework)\Raven.Core.dll</RavenCoreReferencePath>
    <RavenCoreReferencePath Condition="'$(RavenCoreReferencePath)' == '' and '$(RavenCoreTargetFrameworkCandidate)' != '' and Exists('$(RavenCoreTargetFrameworkCandidate)')">$(RavenCoreTargetFrameworkCandidate)</RavenCoreReferencePath>
    <RavenCoreReferencePath Condition="'$(RavenCoreReferencePath)' == '' and Exists('$(MSBuildThisFileDirectory)..\tools\$(RavenCompilerFramework)\Raven.Core.dll')">$(MSBuildThisFileDirectory)..\tools\$(RavenCompilerFramework)\Raven.Core.dll</RavenCoreReferencePath>
    <RavenCoreReferencePath Condition="'$(RavenCoreReferencePath)' == '' and Exists('$(RavenCoreCompilerFrameworkCandidate)')">$(RavenCoreCompilerFrameworkCandidate)</RavenCoreReferencePath>
    <RavenCoreReferencePath Condition="'$(RavenCoreReferencePath)' == '' and Exists('$(RavenCoreCompilerHostCandidate)')">$(RavenCoreCompilerHostCandidate)</RavenCoreReferencePath>
    <RavenEmitCoreTypesOnly Condition="'$(RavenEmitCoreTypesOnly)' == ''">false</RavenEmitCoreTypesOnly>
    <RavenCoreArgument Condition="'$(RavenEmitCoreTypesOnly)' == 'true'">--emit-core-types-only</RavenCoreArgument>
    <RavenCoreArgument Condition="'$(RavenCoreArgument)' == '' and '$(RavenCoreReferencePath)' != ''">--raven-core &quot;$(RavenCoreReferencePath)&quot;</RavenCoreArgument>
    <RavenCoreArgument Condition="'$(RavenCoreArgument)' == ''">--emit-core-types-only</RavenCoreArgument>
    <RavenBuildArgs Condition="'$(RavenBuildArgs)' == ''"></RavenBuildArgs>
    <RavenTargetFrameworkArgument Condition="'$(TargetFramework)' != ''">--framework &quot;$(TargetFramework)&quot;</RavenTargetFrameworkArgument>
    <RavenOutputTypeArgument Condition="'$(OutputType)' == 'Library'">--output-type classlib</RavenOutputTypeArgument>
    <RavenOutputTypeArgument Condition="'$(RavenOutputTypeArgument)' == '' and '$(OutputType)' != ''">--output-type exe</RavenOutputTypeArgument>

    <DefaultLanguageSourceExtension>.rvn</DefaultLanguageSourceExtension>
    <Language>Raven</Language>
    <TargetRuntime>Managed</TargetRuntime>
    <GenerateAssemblyInfo Condition="'$(GenerateAssemblyInfo)' == ''">false</GenerateAssemblyInfo>
    <GenerateTargetFrameworkAttribute Condition="'$(GenerateTargetFrameworkAttribute)' == ''">false</GenerateTargetFrameworkAttribute>
    <ProduceReferenceAssembly Condition="'$(ProduceReferenceAssembly)' == ''">false</ProduceReferenceAssembly>
    <EnableDefaultCompileItems Condition="'$(EnableDefaultCompileItems)' == ''">false</EnableDefaultCompileItems>
    <EnableDefaultEmbeddedResourceItems Condition="'$(EnableDefaultEmbeddedResourceItems)' == ''">false</EnableDefaultEmbeddedResourceItems>
  </PropertyGroup>

  <ItemGroup>
    <AvailableItemName Include="RavenCompile" />
    <PropertyPageSchema Include="$(CommonXamlResourcesDirectory)CSharp.ProjectItemsSchema.xaml" Condition="'$(CommonXamlResourcesDirectory)' != ''" />
    <ProjectCapability Include="Managed" />
    <Compile Remove="**/*.cs" />
    <EmbeddedResource Remove="**/*.resx" />
  </ItemGroup>

  <ItemGroup Condition="'$(IsCrossTargetingBuild)' != 'true' and '$(RavenEmitCoreTypesOnly)' != 'true' and '$(RavenCoreReferencePath)' != ''">
    <Reference Include="Raven.Core">
      <HintPath>$(RavenCoreReferencePath)</HintPath>
      <Private>true</Private>
    </Reference>
  </ItemGroup>

  <PropertyGroup>
    <RavenCommonTargetsPath Condition="'$(IsCrossTargetingBuild)' == 'true'">$(MSBuildToolsPath)\Microsoft.Common.CrossTargeting.targets</RavenCommonTargetsPath>
    <RavenCommonTargetsPath Condition="'$(RavenCommonTargetsPath)' == ''">$(MSBuildToolsPath)\Microsoft.Common.targets</RavenCommonTargetsPath>
  </PropertyGroup>

  <Import Project="$(RavenCommonTargetsPath)" />

  <Target Name="CreateManifestResourceNames" />

  <Target
    Name="CoreCompile"
    DependsOnTargets="$(CoreCompileDependsOn)"
    Inputs="$(MSBuildProjectFullPath);@(RavenCompile);@(ReferencePath);@(ProjectReference);@(PackageReference);@(FrameworkReference)"
    Outputs="@(IntermediateAssembly)"
    Condition="'$(IsCrossTargetingBuild)' != 'true'">
    <PropertyGroup>
      <_RavenIntermediateOutputPath Condition="$([System.IO.Path]::IsPathRooted('$(IntermediateOutputPath)'))">$(IntermediateOutputPath)</_RavenIntermediateOutputPath>
      <_RavenIntermediateOutputPath Condition="'$(_RavenIntermediateOutputPath)' == ''">$([System.IO.Path]::GetFullPath('$(MSBuildProjectDirectory)\$(IntermediateOutputPath)'))</_RavenIntermediateOutputPath>
    </PropertyGroup>

    <Error
      Condition="!Exists('$(RavenCompilerHost)')"
      Text="Built Raven compiler host not found at '$(RavenCompilerHost)'. Build Raven.Compiler first or set &lt;RavenCompilerHost&gt;." />

    <MakeDir Directories="$(_RavenIntermediateOutputPath)" />

    <ItemGroup>
      <_RavenReferencePath Include="@(ReferencePath)" Condition="Exists('%(FullPath)') and '%(Filename)' != 'Raven.Core'" />
    </ItemGroup>

    <PropertyGroup>
      <RavenReferenceArguments>@(_RavenReferencePath->'--refs &quot;%(FullPath)&quot;', ' ')</RavenReferenceArguments>
    </PropertyGroup>

    <Message Importance="High" Text="RavenCompile: $(MSBuildProjectFile) -&gt; @(IntermediateAssembly)" />
    <Exec
      Command="dotnet &quot;$(RavenCompilerHost)&quot; &quot;$(MSBuildProjectFullPath)&quot; -o &quot;$(_RavenIntermediateOutputPath)&quot; $(RavenTargetFrameworkArgument) $(RavenOutputTypeArgument) --no-project-restore $(RavenCoreArgument) $(RavenReferenceArguments) $(RavenBuildArgs)" />

    <MakeDir Directories="@(IntermediateRefAssembly->'%(RootDir)%(Directory)')" Condition="'@(IntermediateRefAssembly)' != ''" />
    <Copy
      SourceFiles="@(IntermediateAssembly)"
      DestinationFiles="@(IntermediateRefAssembly)"
      Condition="'@(IntermediateRefAssembly)' != '' and Exists('@(IntermediateAssembly)')" />

    <ItemGroup>
      <FileWrites Include="@(IntermediateAssembly)" />
      <FileWrites Include="@(IntermediateRefAssembly)" Condition="'@(IntermediateRefAssembly)' != ''" />
      <FileWrites Include="@(IntermediateAssembly->'%(RootDir)%(Directory)%(Filename).pdb')" />
      <FileWrites Include="$(IntermediateOutputPath)$(TargetName).runtimeconfig.json" />
      <FileWrites Include="$(IntermediateOutputPath)$(TargetName)$(ExeExtension)" Condition="'$(OutputType)' != 'Library'" />
    </ItemGroup>
  </Target>
</Project>
